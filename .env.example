# PostgreSQL (Supabase) — chaîne de connexion "Transaction pooler"
DATABASE_URL=postgresql://postgres:[password]@[host]:6543/postgres

# Supabase Auth (vérification JWT côté serveur)
SUPABASE_URL=https://[project].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# API
PORT=3001
# Liste blanche CORS, séparée par des virgules (remplace le joker par défaut)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
# Bascule du cutover (D16/Rollout) : gate uniquement les routes pré-existantes
# (chambres, réservations). Les routes nouvelles (invite, journal d'audit)
# exigent toujours l'auth, peu importe cette variable.
AUTH_ENFORCED=false

# WhatsApp Business (phase 1: liens wa.me ; phase 2: API Cloud)
WHATSAPP_PHONE=+243

# Mobile Money (références de transaction saisies manuellement en v1)
# TTLock (phase 2 — émission automatique des codes PIN)
TTLOCK_CLIENT_ID=
TTLOCK_CLIENT_SECRET=
